            // 复制代理链接函数
            function copyProxyUrl() {
                var targetUrlInput = document.getElementById('targetUrl');
                if (!targetUrlInput) return;
                
                var targetUrl = targetUrlInput.value.trim();
                if (!targetUrl) {
                    alert('⚠️ 请先输入目标网址');
                    targetUrlInput.focus();
                    return;
                }
                
                // 如果没有协议，自动添加 https://
                if (!targetUrl.startsWith('http://') && !targetUrl.startsWith('https://')) {
                    targetUrl = 'https://' + targetUrl;
                }
                
                // 获取当前页面的完整路径（包括PROXY_PATH）
                var currentPath = window.location.pathname;
                // 移除末尾的斜杠（如果有）
                if (currentPath.endsWith('/')) {
                    currentPath = currentPath.slice(0, -1);
                }
                
                // 移除UUID部分（如果存在）
                // UUID格式：xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
                var pathParts = currentPath.split('/').filter(function(part) {
                    return part.length > 0;
                });
                
                // 检查第一部分是否是UUID格式
                if (pathParts.length > 0) {
                    var firstPart = pathParts[0];
                    var uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
                    if (uuidRegex.test(firstPart)) {
                        // 移除UUID部分
                        pathParts.shift();
                    }
                }
                
                // 重新构建路径（不包含UUID）
                var pathWithoutUuid = pathParts.length > 0 ? '/' + pathParts.join('/') : '';
                
                var currentOrigin = window.location.origin;
                var proxyUrl = currentOrigin + pathWithoutUuid + '/' + targetUrl;
                
                // 使用 Clipboard API 复制
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(proxyUrl).then(function() {
                        // 显示复制成功提示
                        var copyBtn = document.getElementById('copyButton');
                        if (copyBtn) {
                            var originalText = copyBtn.innerHTML;
                            copyBtn.innerHTML = '✓ 已复制';
                            copyBtn.classList.add('copied');
                            setTimeout(function() {
                                copyBtn.innerHTML = originalText;
                                copyBtn.classList.remove('copied');
                            }, 2000);
                        }
                    }).catch(function(err) {
                        // 如果 Clipboard API 失败，使用备用方法
                        fallbackCopy(proxyUrl);
                    });
                } else {
                    // 使用备用复制方法
                    fallbackCopy(proxyUrl);
                }
            }
            
            // 备用复制方法
            function fallbackCopy(text) {
                var textArea = document.createElement('textarea');
                textArea.value = text;
                textArea.style.position = 'fixed';
                textArea.style.left = '-999999px';
                textArea.style.top = '-999999px';
                document.body.appendChild(textArea);
                textArea.focus();
                textArea.select();
                try {
                    var successful = document.execCommand('copy');
                    if (successful) {
                        var copyBtn = document.getElementById('copyButton');
                        if (copyBtn) {
                            var originalText = copyBtn.innerHTML;
                            copyBtn.innerHTML = '✓ 已复制';
                            copyBtn.classList.add('copied');
                            setTimeout(function() {
                                copyBtn.innerHTML = originalText;
                                copyBtn.classList.remove('copied');
                            }, 2000);
                        }
                    } else {
                        alert('❌ 复制失败，请手动复制:\n' + text);
                    }
                } catch (err) {
                    alert('❌ 复制失败，请手动复制:\n' + text);
                }
                document.body.removeChild(textArea);
            }
            
            // 将函数暴露到全局作用域，供表单onsubmit使用
            window.redirectToProxy = redirectToProxy;
            window.copyProxyUrl = copyProxyUrl;
            
            // 页面加载完成后，为代理访问输入框添加独立的事件处理
            document.addEventListener('DOMContentLoaded', function() {
                // 自动聚焦到输入框
