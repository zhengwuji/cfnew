        }
    } catch {
        return getHTMLResponse("无效的URL格式");
    }

    if (!actualUrlStr.startsWith("http") && !actualUrlStr.includes("://")) {
        return getRedirect(thisProxyServerUrlHttps + "https://" + actualUrlStr);
    }

    const actualUrl = new URL(actualUrlStr);
    if (actualUrlStr != actualUrl.href) return getRedirect(thisProxyServerUrlHttps + actualUrl.href);

    // 处理请求头
    let clientHeaderWithChange = new Headers();
    
    // 需要移除或替换的请求头（可能泄露真实信息）
    const headersToRemove = [
        'X-Forwarded-For',
        'X-Real-Ip',
        'Cf-Connecting-Ip',
        'Cf-Worker',
        'Cf-Ray',
        'Cf-Visitor',
        'X-Forwarded-Proto',
        'X-Forwarded-Host',
        'X-Original-Url',
        'X-Forwarded-Server',
        'X-Forwarded-Port',
        'Forwarded',
        'Via',
        'True-Client-Ip',
        'X-Client-Ip',
        'X-Originating-Ip',
        'X-Remote-Ip',
        'X-Remote-Addr',
        // 移除客户端发送的 Sec-Fetch-* 请求头，我们将重新设置正确的值
        'Sec-Fetch-Dest',
        'Sec-Fetch-Mode',
        'Sec-Fetch-Site',
        'Sec-Fetch-User',
        'Sec-Ch-Ua',
        'Sec-Ch-Ua-Mobile',
        'Sec-Ch-Ua-Platform'
    ];
    
    // 需要替换的请求头
    const headersToReplace = {
        'User-Agent': generateRandomProxyUserAgent(),
        'X-Forwarded-For': generateRandomProxyIP(),
        'X-Real-Ip': generateRandomProxyIP(),
        'Cf-Connecting-Ip': generateRandomProxyIP(),
        'True-Client-Ip': generateRandomProxyIP(),
        'X-Client-Ip': generateRandomProxyIP(),
        'X-Originating-Ip': generateRandomProxyIP(),
        'X-Remote-Ip': generateRandomProxyIP(),
        'X-Remote-Addr': generateRandomProxyIP()
    };
    
    request.headers.forEach((value, key) => {
        var headerKey = key.toLowerCase();
        
