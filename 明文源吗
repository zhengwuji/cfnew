        // 格式化IP地址显示（中文形式）- 前端函数
        function formatIPDisplay(ip) {
            if (!ip) return '未知IP地址';
            
            // 判断IP类型
            const isIPv6 = ip.includes(':');
            
            if (isIPv6) {
                // IPv6地址 - 显示为"IPv6: xxx"格式
                return 'IPv6: ' + ip;
            } else {
                // IPv4地址 - 显示为"IPv4: xxx"格式
                return 'IPv4: ' + ip;
            }
        }
        
