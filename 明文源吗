        // 大多数API可以直接使用IPv6地址（浏览器会自动处理URL中的IPv6地址）
        // 但为了兼容性，我们同时准备编码和非编码版本
        const apiIP = ip; // 直接使用IP地址（对于IPv6，浏览器会自动处理）
        const encodedIP = encodeURIComponent(ip); // 编码版本作为备用
        
        // 使用多个API作为备用，提高成功率
        const apis = [
