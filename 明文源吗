        const tgForm = new FormData();
        const inferredExt = (file.type && file.type.split('/')[1]) || 'jpg';
        const filename = file.name || ('image.' + inferredExt);
        tgForm.append('photo', file, filename);
        
        // 先发送到 Telegram 频道（添加超时控制）
        const sendResp = await fetchWithTimeout('https://api.telegram.org/bot' + tgBotToken + '/sendPhoto?chat_id=' + encodeURIComponent(tgChatId), {
